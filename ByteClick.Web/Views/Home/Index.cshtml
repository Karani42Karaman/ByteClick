@using ByteClick.Web.Controllers
@model DashboardViewModel
@{
    Layout = null;
    // Hesap özeti kartı için güvenli varsayılan değerler
    var balance = Model.Account?.Balance ?? 0;
    var equity = Model.Account?.Equity ?? 0;
    var marginLevel = Model.Account?.MarginLevel ?? 0;
    var openPos = Model.Account?.OpenPositions ?? 0;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ByteClick Pro Trading Dashboard</title>

    <style>
        :root {
            --bg-main: #060913;
            --bg-card: #0d1224;
            --border-color: #1e293b;
            --primary: #3b82f6;
            --primary-glow: rgba(59, 130, 246, 0.15);
            --success: #10b981;
            --success-glow: rgba(16, 185, 129, 0.1);
            --danger: #ef4444;
            --danger-glow: rgba(239, 68, 68, 0.1);
            --warning: #f59e0b;
            --text-muted: #64748b;
            --text-main: #f8fafc;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-main);
            color: var(--text-main);
            padding: 24px;
            line-height: 1.5;
        }

        .container {
            max-width: 1700px;
            margin: 0 auto;
        }

        /* HEADER */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding: 16px 24px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo {
            font-size: 22px;
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #60a5fa, #34d399);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .live-status {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 700;
            background: var(--success-glow);
            color: var(--success);
            padding: 6px 14px;
            border-radius: 20px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .dot {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%

        {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
        }

        }

        /* METRICS GRID */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .metric-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 24px;
            position: relative;
            overflow: hidden;
            transition: all 0.2s ease;
        }

            .metric-card:hover {
                border-color: var(--primary);
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(59, 130, 246, 0.08);
            }

        .metric-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }

        .metric-value {
            font-size: 32px;
            font-weight: 700;
            font-family: 'Courier New', monospace;
            letter-spacing: -0.5px;
        }

        .metric-sub {
            margin-top: 8px;
            font-size: 12px;
            color: var(--text-muted);
            display: flex;
            justify-content: space-between;
        }

        /* COLORS & EFFECTS */
        .text-green {
            color: var(--success);
        }

        .text-red {
            color: var(--danger);
        }

        .text-blue {
            color: var(--primary);
        }

        .text-orange {
            color: var(--warning);
        }

        /* MAIN CONTENT LAYOUT */
        .dashboard-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        .board-section {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        }

        .section-title {
            padding: 20px;
            font-size: 15px;
            font-weight: 700;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, 0.01);
        }

        .section-count {
            background: rgba(255, 255, 255, 0.05);
            padding: 4px 10px;
            border-radius: 8px;
            font-size: 12px;
            color: var(--text-muted);
        }

        /* SMART TABLES */
        .table-container {
            overflow-x: auto;
            width: 100%;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th {
            background: rgba(0, 0, 0, 0.2);
            padding: 14px 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
        }

        td {
            padding: 14px 20px;
            border-bottom: 1px solid rgba(30, 41, 59, 0.5);
            font-size: 13px;
        }

        tr:hover td {
            background: rgba(255, 255, 255, 0.01);
        }

        tr:last-child td {
            border-bottom: none;
        }

        /* REUSABLE BADGES */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 700;
            font-family: monospace;
        }

        .badge-buy {
            background: rgba(16, 185, 129, 0.12);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .badge-sell {
            background: rgba(239, 68, 68, 0.12);
            color: var(--danger);
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        .badge-open {
            background: rgba(59, 130, 246, 0.12);
            color: var(--primary);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .badge-closed {
            background: rgba(100, 116, 139, 0.12);
            color: var(--text-muted);
        }

        .mono {
            font-family: 'Courier New', monospace;
            font-weight: 600;
        }

        /* LATENCY SPEEDOMETER */
        .speed-pill {
            font-family: monospace;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
        }

        .speed-fast {
            background: var(--success-glow);
            color: var(--success);
        }

        .speed-medium {
            background: var(--danger-glow);
            color: var(--warning);
        }

        .speed-slow {
            background: var(--danger-glow);
            color: var(--danger);
        }

        .empty-state {
            padding: 60px 20px;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
        }

        /* RESPONSIVE DESIGN */
        @@media (max-width: 1280px) {
            .dashboard-layout

        {
            grid-template-columns: 1fr;
        }

        }

        @@media (max-width: 768px) {
            body

        {
            padding: 12px;
        }

        .metrics-grid {
            grid-template-columns: 1fr;
        }

        .metric-value {
            font-size: 26px;
        }

        }
    </style>
</head>
<body>

    <div class="container">

        <div class="header">
            <div class="logo-area">
                <div class="logo">⚡ BYTECLICK ENGINE</div>
            </div>
            <div class="live-status">
                <div class="dot"></div>
                LIVE ALGO TRADING ACTIVE
            </div>
        </div>

        <div class="metrics-grid">

            <div class="metric-card">
                <div class="metric-label">Toplam Net Kar/Zarar</div>
                <div class="metric-value @(Model.TotalProfit >= 0 ? "text-green" : "text-red")">
                    @(Model.TotalProfit >= 0 ? "+" : "")$@Model.TotalProfit.ToString("N2")
                </div>
                <div class="metric-sub">
                    <span>Sinyal Başarı Oranı:</span>
                    <span class="text-blue font-weight:700;">%@Model.WinRate.ToString("F1")</span>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-label">Hesap Bakiyesi (Balance)</div>
                <div class="metric-value text-blue">$@balance.ToString("N2")</div>
                <div class="metric-sub">
                    <span>Mevcut Varlık (Equity):</span>
                    <span>$@equity.ToString("N2")</span>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-label">Teminat Seviyesi (Margin Level)</div>
                <div class="metric-value @(marginLevel < 200 && marginLevel > 0 ? "text-red" : "text-green")">
                    %@marginLevel.ToString("N1")
                </div>
                <div class="metric-sub">
                    <span>Açık Pozisyon Adedi:</span>
                    <span class="text-orange">@openPos Adet</span>
                </div>
            </div>

            <div class="metric-card">
                <div class="metric-label">Ortalama Ağ Gecikmesi</div>
                <div class="metric-value @(Model.AvgExecutionDelay > 1500 ? "text-red" : "text-green")">
                    @Model.AvgExecutionDelay.ToString("N0") <small style="font-size: 16px; opacity:0.5;">ms</small>
                </div>
                <div class="metric-sub">
                    <span>Hedef Limit:</span>
                    <span>&lt; 1000ms</span>
                </div>
            </div>

        </div>

        <div class="dashboard-layout">

            <div class="board-section">
                <div class="section-title">
                    <span>📡 Gelen TradingView Sinyalleri</span>
                    <span class="section-count">Son @Model.Alerts.Count Kayıt</span>
                </div>

                <div class="table-container data-table">
                    @if (Model.Alerts.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Zaman</th>
                                    <th>Sembol</th>
                                    <th>Aksiyon</th>
                                    <th>Sinyal Fiyatı</th>
                                    <th>TV Gecikme</th>
                                    <th>MT5 Gecikme</th>
                                    <th>Toplam</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in Model.Alerts.Take(30))
                                {
                                    var totalDelay = alert.DelayMs + alert.ProcessDelayMs;
                                    string speedClass = totalDelay < 1000 ? "speed-fast" : (totalDelay < 2500 ? "speed-medium" : "speed-slow");

                                    <tr>
                                        <td class="mono text-muted">@alert.CreatedAt.ToString("HH:mm:ss")</td>
                                        <td class="mono">@alert.Symbol</td>
                                        <td>
                                            <span class="badge @(alert.Action == "BUY" ? "badge-buy" : "badge-sell")">
                                                @alert.Action
                                            </span>
                                        </td>
                                        <td class="mono">$@alert.Price.ToString("N5")</td>
                                        <td><span class="speed-pill speed-fast">@alert.DelayMs.ToString("N0")ms</span></td>
                                        <td><span class="speed-pill speed-medium">@alert.ProcessDelayMs.ToString("N0")ms</span></td>
                                        <td><span class="speed-pill @speedClass">@totalDelay.ToString("N0")ms</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">Henüz sinyal verisi veritabanına ulaşmadı.</div>
                    }
                </div>
            </div>

            <div class="board-section">
                <div class="section-title">
                    <span>💼 Canlı MT5 İşlem Günlükleri</span>
                    <span class="section-count">Son @Model.TradeLogs.Count İşlem</span>
                </div>

                <div class="table-container ">
                    @if (Model.TradeLogs.Any())
                    {
                        <table>
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Sembol</th>
                                    <th>Yön</th>
                                    <th>Giriş/Çıkış</th>
                                    <th>Net Kar</th>
                                    <th>Süre</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var trade in Model.TradeLogs.Take(30))
                                {
                                    var durationMin = trade.CloseTime.HasValue
                                    ? (trade.CloseTime.Value - trade.OpenTime).TotalMinutes
                                    : (DateTime.Now - trade.OpenTime).TotalMinutes;

                                    <tr>
                                        <td class="mono text-muted" style="font-size:11px;">#@trade.Ticket</td>
                                        <td class="mono">@trade.Symbol</td>
                                        <td>
                                            <span class="badge @(trade.Type == "BUY" ? "badge-buy" : "badge-sell")">
                                                @trade.Type
                                            </span>
                                        </td>
                                        <td class="mono">
                                            <div>$@trade.OpenPrice.ToString("N5")</div>
                                            <div style="font-size:11px;" class="text-muted">
                                                @(trade.ClosePrice.HasValue ? "$" + trade.ClosePrice.Value.ToString("N5") : "Açık İşlem")
                                            </div>
                                        </td>
                                        <td class="mono">
                                            @if (trade.Profit.HasValue)
                                            {
                                                <span class="@(trade.Profit >= 0 ? "text-green" : "text-red")">
                                                    @(trade.Profit >= 0 ? "+" : "")$@trade.Profit.Value.ToString("N2")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="mono" style="font-size:12px;">
                                            @if (durationMin < 60)
                                            {
                                                <span>@durationMin.ToString("N0") dk</span>
                                            }
                                            else
                                            {
                                                <span>@Math.Floor(durationMin / 60).ToString("N0") sa @Math.Floor(durationMin % 60).ToString("N0") dk</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(trade.IsOpen ? "badge-open" : "badge-closed")">
                                                @(trade.IsOpen ? "AÇIK" : "KAPALI")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">Terminal üzerinden yapılmış herhangi bir işlem kaydı yok.</div>
                    }
                </div>
            </div>

        </div>

    </div>

    <script>
        // Sayfayı her 15 saniyede bir akıcı şekilde otomatik yeniler
        setTimeout(() => {
            location.reload();
        }, 2000);
    </script>

</body>
</html>