@using ByteClick.Web.Controllers
@model DashboardViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <title>ByteClick | Pro Analyzer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0f1d;
            --card: #161e31;
            --accent: #38bdf8;
            --success: #22c55e;
            --danger: #ef4444;
        }

        body {
            background-color: var(--bg);
            color: #e2e8f0;
            font-family: 'Inter', sans-serif;
        }

        .glass-card {
            background: var(--card);
            border: 1px solid #2d3748;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }

        .stat-label {
            font-size: 0.75rem;
            color: #94a3b8;
            text-uppercase;
            font-weight: 600;
        }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            display: block;
        }

        .latency-bad {
            color: var(--danger);
        }

        .latency-good {
            color: var(--success);
        }

        .table {
            --bs-table-bg: transparent;
            --bs-table-color: #e2e8f0;
            border-color: #2d3748;
        }
    </style>
</head>
<body class="p-4">

    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">⚡ BYTECLICK <span class="text-muted fw-light">ANALYSIS TERMINAL</span></h3>
            <div class="badge bg-primary">LIVE USD FEED</div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="glass-card">
                    <span class="stat-label">TOPLAM KÂR/ZARAR</span>
                    <span class="stat-value @(Model.TotalProfit >= 0 ? "text-success" : "text-danger")">
                        $@Model.TotalProfit.ToString("N2")
                    </span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card text-center">
                    <span class="stat-label">WIN RATE</span>
                    <span class="stat-value text-info">%@Model.WinRate.ToString("F1")</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card">
                    <span class="stat-label">SİNYAL GECİKMESİ (AVG)</span>
                    <span class="stat-value @(Model.AvgExecutionDelay > 1000 ? "latency-bad" : "latency-good")">
                        @Model.AvgExecutionDelay.ToString("N0") <small style="font-size: 0.8rem">ms</small>
                    </span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass-card">
                    <span class="stat-label">YATIRILAN HACİM</span>
                    <span class="stat-value text-warning">$@Model.TotalInvested.ToString("N0")</span>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-6">
                <div class="glass-card h-100">
                    <h6 class="mb-3 text-muted">TV Sinyal Akışı</h6>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Zaman</th>
                                    <th>Sembol</th>
                                    <th>Aksiyon</th>
                                    <th>TV Gecikme</th>
                                    <th>MT5 İşleme</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.Alerts)
                                {
                                    <tr>
                                        <td><small>@a.CreatedAt.ToString("HH:mm:ss")</small></td>
                                        <td><strong>@a.Symbol</strong></td>
                                        <td><span class="badge @(a.Action == "BUY" ? "bg-success" : "bg-danger")">@a.Action</span></td>
                                        <td class="text-info">@a.DelayMs.ToString("N0")ms</td>
                                        <td class="text-warning">@a.ProcessDelayMs.ToString("N0")ms</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-xl-6">
                <div class="glass-card h-100">
                    <h6 class="mb-3 text-muted">MT5 İşlem Defteri</h6>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Açılış</th>
                                    <th>Kar/Zarar</th>
                                    <th>Süre</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.TradeLogs)
                                {
                                    <tr>
                                        <td><small class="text-muted">#@t.Ticket</small></td>
                                        <td>$@t.OpenPrice.ToString("N2")</td>
                                        <td class="fw-bold @(t.Profit >= 0 ? "text-success" : "text-danger")">
                                            @(t.Profit.HasValue ? "$" + t.Profit.Value.ToString("N2") : "---")
                                        </td>
                                        <td>
                                            @if (t.CloseTime.HasValue)
                                            {
                                                <small>@((t.CloseTime.Value - t.OpenTime).Minutes) dk</small>
                                            }
                                        </td>
                                        <td>@(t.IsOpen ? "⏳ AÇIK" : "🏁 KAPALI")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>setTimeout(() => location.reload(), 10000);</script>
</body>
</html>