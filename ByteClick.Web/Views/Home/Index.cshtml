@model List<Alert>

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>ByteClick | Signal Monitor</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: #e2e8f0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { background-color: #1e293b; border: 1px solid #334155; border-radius: 12px; margin-top: 20px; }
        .table { color: #e2e8f0; border-color: #334155; }
        .status-badge { padding: 4px 8px; border-radius: 6px; font-size: 12px; font-weight: bold; }
        .bg-buy { background-color: #059669; color: white; }
        .bg-sell { background-color: #dc2626; color: white; }
        .bg-wait { background-color: #4b5563; color: white; }
        .latency-good { color: #10b981; } /* 0-500ms */
        .latency-warn { color: #f59e0b; } /* 500-2000ms */
        .latency-bad { color: #ef4444; }  /* 2000ms+ */
        .header-stats { display: flex; gap: 20px; margin-bottom: 20px; }
        .stat-box { background: #1e293b; padding: 15px; border-radius: 10px; flex: 1; border: 1px solid #334155; }
    </style>
</head>
<body>

    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>🚀 ByteClick Signal Monitor</h2>
            <div>
                <button onclick="clearDb()" class="btn btn-outline-danger btn-sm">🗑️ Verileri Temizle</button>
                <a href="/webhook/tradingview/health" target="_blank" class="btn btn-outline-info btn-sm">🏥 Sistem Durumu</a>
            </div>
        </div>

        <div class="header-stats">
            <div class="stat-box">
                <small class="text-muted">Toplam Sinyal</small>
                <h3 class="m-0">@Model.Count()</h3>
            </div>
            <div class="stat-box">
                <small class="text-muted">Ort. Gecikme (Webhook)</small>
                <h3 class="m-0 text-info">@(Model.Any() ? Model.Average(x => x.DelayMs).ToString("F0") : "0") ms</h3>
            </div>
            <div class="stat-box">
                <small class="text-muted">Bekleyen İşlem</small>
                <h3 class="m-0 text-warning">@Model.Count(x => !x.IsProcessed)</h3>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Zaman (Sinyal)</th>
                                <th>Sembol</th>
                                <th>İşlem</th>
                                <th>Fiyat</th>
                                <th>Lot/SL/TP</th>
                                <th>Webhook Latency</th>
                                <th>MT5 Execution</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="small">@item.TVTimestamp.AddHours(3).ToString("HH:mm:ss.fff")</td>
                                    <td><strong>@item.Symbol</strong> <br /><small class="text-muted">@item.Exchange / @item.Interval</small></td>
                                    <td>
                                        <span class="status-badge @(item.Action == "BUY" ? "bg-buy" : item.Action == "SELL" ? "bg-sell" : "bg-wait")">
                                            @item.Action
                                        </span>
                                    </td>
                                    <td>@item.Price.ToString("F5")</td>
                                    <td class="small">L:@item.Lot / S:@item.SL / T:@item.TP</td>
                                    <td class="@(item.DelayMs < 500 ? "latency-good" : "latency-warn")">
                                        ⚡ @item.DelayMs.ToString("F0") ms
                                    </td>
                                    <td class="@(item.ProcessDelayMs < 1000 ? "latency-good" : "latency-bad")">
                                        ⚙️ @(item.IsProcessed? item.ProcessDelayMs.ToString("F0") + " ms" : "Bekliyor...")
                                    </td>
                                    <td>
                                        @if (item.IsProcessed)
                                        {
                                            <span class="text-success">✅ İşlendi</span>
                                        }
                                        else
                                        {

                                            <span class="text-warning">⏳ MT5 Bekleniyor</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function clearDb() {
            if(confirm("Tüm verileri silmek istediğine emin misin?")) {
                const response = await fetch('/webhook/tradingview/clear', { method: 'DELETE' });
                if(response.ok) location.reload();
            }
        }
        // Sayfayı her 10 saniyede bir yenile
        setTimeout(() => { location.reload(); }, 10000);
    </script>

</body>
</html>